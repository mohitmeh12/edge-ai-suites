# Quick Start - Interactive launcher for ROS2 KPI Toolkit

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Colors
GREEN=$(printf '\033[0;32m')
BLUE=$(printf '\033[0;34m')
YELLOW=$(printf '\033[1;33m')
NC=$(printf '\033[0m')

# Auto-setup
source ./auto-setup.sh

clear
echo "=========================================="
echo "  ROS2 KPI Toolkit - Quick Start"
echo "=========================================="
echo ""
echo "What would you like to do?"
echo ""
echo "  ${GREEN}1)${NC} Monitor my ROS2 application"
echo "  ${GREEN}2)${NC} Wandering simulation"
echo "  ${GREEN}3)${NC} Pick-n-Place simulation"
echo "  ${GREEN}4)${NC} Analyze rosbag / results"
echo "  ${GREEN}5)${NC} Quick health check"
echo "  ${GREEN}6)${NC} Grafana dashboards"
echo "  ${GREEN}7)${NC} Advanced options"
echo "  ${GREEN}0)${NC} Exit"
echo ""
read -p "Choice [0-7]: " choice

case $choice in
    1)
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  Monitor ROS2 Application"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""

        # Check if any nodes are running
        nodes=$(ros2 node list 2>/dev/null | grep -v "^$")
        node_count=$(echo "$nodes" | grep -v "^$" | wc -l)

        if [ "$node_count" -eq 0 ]; then
            echo "${YELLOW}⚠️  No ROS2 nodes detected.${NC}"
            echo ""
            echo "Please start your ROS2 application first, then run this again."
            echo ""
            echo "Examples:"
            echo "  ros2 launch wandering_gazebo_tutorial wandering.launch.py"
            echo "  ros2 run turtlesim turtlesim_node"
            exit 1
        fi

        echo "Available nodes:"
        echo "$nodes" | nl -w2 -s") "
        echo ""
        read -p "Monitor specific node? (enter number or 'a' for all): " node_choice

        if [[ "$node_choice" =~ ^[0-9]+$ ]]; then
            target_node=$(echo "$nodes" | sed -n "${node_choice}p")
            echo ""
            echo "Monitoring: $target_node"
            read -p "Duration (seconds, default=60): " duration
            duration=${duration:-60}
            make monitor-node NODE="$target_node" DURATION="$duration"
        else
            echo ""
            read -p "Duration (seconds, default=60): " duration
            duration=${duration:-60}
            make monitor DURATION="$duration"
        fi
        ;;

    2)
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  Wandering Simulation"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo "  ${GREEN}1)${NC} Single run  (monitor + KPI analysis)"
        echo "  ${GREEN}2)${NC} Single run  + rosbag recording"
        echo "  ${GREEN}3)${NC} Single run  + rosbag recording + plots"
        echo "  ${GREEN}4)${NC} Benchmark   (multiple runs, then aggregate KPIs)"
        echo "  ${GREEN}0)${NC} Back"
        echo ""
        read -p "Choice: " w_choice

        case $w_choice in
            1)
                read -p "Goals to reach (default=3, 0=ignore): " goals
                goals=${goals:-3}
                read -p "Timeout in seconds (default=120): " timeout
                timeout=${timeout:-120}
                make wandering GOALS="$goals" TIMEOUT="$timeout"
                ;;
            2)
                read -p "Goals to reach (default=3, 0=ignore): " goals
                goals=${goals:-3}
                read -p "Timeout in seconds (default=120): " timeout
                timeout=${timeout:-120}
                make wandering-record GOALS="$goals" TIMEOUT="$timeout"
                ;;
            3)
                read -p "Goals to reach (default=3, 0=ignore): " goals
                goals=${goals:-3}
                read -p "Timeout in seconds (default=120): " timeout
                timeout=${timeout:-120}
                make wandering-record-plot GOALS="$goals" TIMEOUT="$timeout"
                ;;
            4)
                read -p "Number of runs (default=25): " runs
                runs=${runs:-25}
                read -p "Timeout per run in seconds (default=120): " timeout
                timeout=${timeout:-120}
                read -p "Pause between runs in seconds (default=30): " pause
                pause=${pause:-30}
                make wandering-benchmark RUNS="$runs" TIMEOUT="$timeout" PAUSE="$pause"
                ;;
            0) echo "Back."; exit 0 ;;
            *) echo "Invalid choice"; exit 1 ;;
        esac
        ;;

    3)
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  Pick-n-Place Simulation"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo "  ${GREEN}1)${NC} Single run  (monitor + KPI analysis)"
        echo "  ${GREEN}2)${NC} Single run  + rosbag recording"
        echo "  ${GREEN}3)${NC} Single run  + rosbag recording + plots"
        echo "  ${GREEN}4)${NC} Benchmark   (multiple runs, then aggregate KPIs)"
        echo "  ${GREEN}0)${NC} Back"
        echo ""
        read -p "Choice: " pn_choice

        case $pn_choice in
            1)
                read -p "Timeout in seconds (default=300): " timeout
                timeout=${timeout:-300}
                make picknplace-run PN_TIMEOUT="$timeout"
                ;;
            2)
                read -p "Timeout in seconds (default=300): " timeout
                timeout=${timeout:-300}
                make picknplace-record PN_TIMEOUT="$timeout"
                ;;
            3)
                read -p "Timeout in seconds (default=300): " timeout
                timeout=${timeout:-300}
                make picknplace-record-plot PN_TIMEOUT="$timeout"
                ;;
            4)
                read -p "Number of runs (default=25): " runs
                runs=${runs:-25}
                read -p "Timeout per run in seconds (default=300): " timeout
                timeout=${timeout:-300}
                read -p "Pause between runs in seconds (default=30): " pause
                pause=${pause:-30}
                make picknplace-benchmark RUNS="$runs" PN_TIMEOUT="$timeout" PAUSE="$pause"
                ;;
            0) echo "Back."; exit 0 ;;
            *) echo "Invalid choice"; exit 1 ;;
        esac
        ;;

    4)
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  Analyze Rosbag / Results"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo "  ${GREEN}1)${NC} Analyze last wandering session bag"
        echo "  ${GREEN}2)${NC} Analyze last pick-n-place session bag"
        echo "  ${GREEN}3)${NC} Analyze a specific bag (enter path)"
        echo "  ${GREEN}4)${NC} Aggregate benchmark results (enter bench dir)"
        echo "  ${GREEN}5)${NC} View cross-session KPI averages"
        echo "  ${GREEN}0)${NC} Back"
        echo ""
        read -p "Choice: " analyze_choice

        case $analyze_choice in
            1) make analyze-last-wandering ;;
            2) make analyze-last-picknplace ;;
            3)
                read -p "Path to rosbag2 directory: " bag_path
                if [ -z "$bag_path" ]; then
                    echo "No path entered."
                    exit 1
                fi
                make analyze-bag BAG="$bag_path"
                ;;
            4)
                read -p "Path to bench_* directory: " bench_path
                if [ -z "$bench_path" ]; then
                    echo "No path entered."
                    exit 1
                fi
                make analyze-benchmark BENCH="$bench_path"
                ;;
            5)
                read -p "Number of recent sessions to average (default=5): " runs
                runs=${runs:-5}
                make view-average RUNS="$runs"
                ;;
            0) echo "Back."; exit 0 ;;
            *) echo "Invalid choice"; exit 1 ;;
        esac
        ;;

    5)
        echo ""
        echo "Running quick health check (30 seconds)..."
        make quick-check
        ;;

    6)
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  Grafana Dashboards"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo "  ${GREEN}1)${NC} Start Grafana/Prometheus"
        echo "  ${GREEN}2)${NC} Stop Grafana/Prometheus"
        echo "  ${GREEN}3)${NC} Check status"
        echo "  ${GREEN}4)${NC} Open Grafana in browser"
        echo ""
        read -p "Choice: " grafana_choice

        case $grafana_choice in
            1) make grafana-start ;;
            2) make grafana-stop ;;
            3) make grafana-status ;;
            4) make grafana-open ;;
            *) echo "Invalid choice" ;;
        esac
        ;;

    7)
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  Advanced Options"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo "  ${GREEN}1)${NC} Extended monitoring (5 minutes)"
        echo "  ${GREEN}2)${NC} Remote monitoring"
        echo "  ${GREEN}3)${NC} Interactive heatmap"
        echo "  ${GREEN}4)${NC} Visualize last session"
        echo "  ${GREEN}5)${NC} Show all commands (make help)"
        echo ""
        read -p "Choice: " advanced_choice

        case $advanced_choice in
            1)
                read -p "Node name (or press Enter for all): " node_name
                if [ -n "$node_name" ]; then
                    make monitor-long NODE="$node_name"
                else
                    make monitor-long
                fi
                ;;
            2)
                read -p "Remote IP address: " remote_ip
                read -p "Remote user (default=$USER): " remote_user
                remote_user=${remote_user:-$USER}
                make monitor-remote REMOTE_IP="$remote_ip" REMOTE_USER="$remote_user"
                ;;
            3) make interactive-heatmap ;;
            4) make visualize-last ;;
            5) make help ;;
            *) echo "Invalid choice" ;;
        esac
        ;;

    0)
        echo "Goodbye!"
        exit 0
        ;;

    *)
        echo "Invalid choice"
        exit 1
        ;;
esac

echo ""
echo "Done!"
